# =============================================================================
# Sandbox Apps — root .gitignore (multi-language CI/CD practice repo)
# =============================================================================

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Secrets & local environment (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
secrets/

# -----------------------------------------------------------------------------
# Logs & temp
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so

# Tests & type check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Virtual environments
.venv/
venv/
ENV/
env.bak/
venv.bak/

# Packaging / build (PulseBoard & generic Python)
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/
wheels/
*.manifest

.ipynb_checkpoints/

# PulseBoard default SQLite location
Python/data/
*.sqlite3

# -----------------------------------------------------------------------------
# Node / JavaScript / TypeScript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

.next/
.nuxt/
.svelte-kit/
.vite/
*.tsbuildinfo
.eslintcache
.parcel-cache

# -----------------------------------------------------------------------------
# Java / Gradle / Scala · sbt
# -----------------------------------------------------------------------------
**/out/
.project
.classpath
.settings/
.factorypath

# Scala sbt (+ Maven/T Gradle) builds — also covers Cargo `target/` for Rust crates
target/
.scala-build/

# Metals / BSP / Bloop (Scala editors & tooling)
.metals/
.bsp/
.bloop/

*.class
*.jar
*.war
*.ear
*.iml
.gradle/
gradle-app.setting
build/

# HotSpot crash logs from local JVM runs
hs_err_pid*
replay_pid*

# -----------------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
vendor/
cover.out
*.out

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------
# `target/` is ignored globally under JVM · Scala · sbt section above.
# Commit Cargo.lock for applications/bins where you pin deps; ignore binaries only via target/.

# -----------------------------------------------------------------------------
# .NET / C#
# -----------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
*.user
*.suo
*.userprefs
*.rsuser
project.lock.json
artifacts/

# -----------------------------------------------------------------------------
# C / C++
# -----------------------------------------------------------------------------
*.o
*.a
*.lib
*.dll
*.so
*.dylib
cmake-build-*/

# -----------------------------------------------------------------------------
# PHP / Composer
# -----------------------------------------------------------------------------
/vendor/

# -----------------------------------------------------------------------------
# Ruby
# -----------------------------------------------------------------------------
/.bundle/
vendor/bundle
*.gem

# -----------------------------------------------------------------------------
# Terraform & IaC
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!*.tfvars.example

# -----------------------------------------------------------------------------
# Docker (local overrides only)
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Misc / coverage / CI artifacts
# -----------------------------------------------------------------------------
dist/
*.bak
.cache/
coverage/
